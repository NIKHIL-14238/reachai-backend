# Database - Use Neon (https://neon.tech) for free PostgreSQL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Anthropic API Key - Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Channel Service URL - Where your channel service is deployed
CHANNEL_SERVICE_URL=http://localhost:4000

# This CRM's public URL (so channel service can call back)
CRM_CALLBACK_URL=http://localhost:3000

# Server port
PORT=3000
